generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum MangaStatus {
  ONGOING
  COMPLETED
  CATCHING_UP
  FINISHED_RELEASING
  HIATUS
}

enum UserRole {
  READER
  ADMIN
}

enum SubscriptionPlan {
  TWO_WEEKS
  ONE_MONTH
  THREE_MONTHS
  SIX_MONTHS
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  EXPIRED
  CANCELLED
}

// ─── Core content ─────────────────────────────────────────────────────────────

model Manga {
  id          String      @id @default(nanoid())
  mangaName   String
  description String?
  coverImage  String?
  homeCoverImage   String?
  detailCoverImage String?
  // Curated related images the reader can pick as their personal cover.
  posterOptions    String[] @default([])
  // Admin-chosen default poster (one of posterOptions). Falls back to
  // detailCoverImage/coverImage when null.
  defaultPoster    String?
  titleFont   String?
  author      String?
  artist      String?
  status      MangaStatus @default(ONGOING)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  chapters        Chapter[]
  genres          MangaGenre[]
  ratings         Rating[]
  bookmarks       Bookmark[]
  comments        Comment[]
  readingProgress ReadingProgress[]
  posterChoices   UserPosterChoice[]
}

model Genre {
  id   String @id @default(nanoid())
  name String @unique

  mangas MangaGenre[]
}

// Many-to-many join table
model MangaGenre {
  mangaId String
  genreId String

  manga Manga @relation(fields: [mangaId], references: [id], onDelete: Cascade)
  genre Genre @relation(fields: [genreId], references: [id], onDelete: Cascade)

  @@id([mangaId, genreId])
}

model Chapter {
  id            String   @id @default(nanoid())
  mangaId       String
  chapterNumber Float
  title         String?
  coverImage    String?
  badgeImage    String?
  badgeScale    Int?
  publishedAt   DateTime @default(now())
  createdAt     DateTime @default(now())

  manga           Manga             @relation(fields: [mangaId], references: [id], onDelete: Cascade)
  pages           Page[]
  readingProgress ReadingProgress[]

  @@unique([mangaId, chapterNumber])
  @@index([mangaId])
}

model Page {
  id         String @id @default(nanoid())
  chapterId  String
  pageNumber Int
  imageUrl   String
  width      Int?
  height     Int?

  chapter Chapter @relation(fields: [chapterId], references: [id], onDelete: Cascade)

  @@unique([chapterId, pageNumber])
  @@index([chapterId])
}

// ─── Users ────────────────────────────────────────────────────────────────────

model User {
  id           String   @id @default(nanoid())
  email        String   @unique
  clerkId      String   @unique
  username     String?  @unique
  avatarUrl    String?
  role         UserRole @default(READER)
  // Denormalized cache of the current subscription expiry for a fast gate
  // check. Sourced from Subscription rows whenever a payment succeeds.
  premiumUntil DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  ratings         Rating[]
  bookmarks       Bookmark[]
  comments        Comment[]
  readingProgress ReadingProgress[]
  posterChoices   UserPosterChoice[]
  payments        Payment[]
  subscriptions   Subscription[]
}

model Comment {
  id        String   @id @default(nanoid())
  mangaId   String
  userId    String
  parentId  String?
  body      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  manga   Manga    @relation(fields: [mangaId], references: [id], onDelete: Cascade)
  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent  Comment? @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies Comment[] @relation("CommentReplies")

  @@index([mangaId])
  @@index([userId])
  @@index([parentId])
}

// ─── User activity ────────────────────────────────────────────────────────────

model ReadingProgress {
  id        String   @id @default(nanoid())
  userId    String
  mangaId   String
  chapterId String
  readAt    DateTime @default(now()) @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  manga   Manga   @relation(fields: [mangaId], references: [id], onDelete: Cascade)
  chapter Chapter @relation(fields: [chapterId], references: [id], onDelete: Cascade)

  // One record per user per chapter; readAt tracks the most recent open.
  @@unique([userId, chapterId])
  @@index([userId, readAt])
  @@index([userId, mangaId])
}

model UserPosterChoice {
  id        String   @id @default(nanoid())
  userId    String
  mangaId   String
  posterUrl String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  manga Manga @relation(fields: [mangaId], references: [id], onDelete: Cascade)

  // One chosen poster per user per manga.
  @@unique([userId, mangaId])
  @@index([userId])
}

model Bookmark {
  id        String   @id @default(nanoid())
  userId    String
  mangaId   String
  createdAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  manga Manga @relation(fields: [mangaId], references: [id], onDelete: Cascade)

  @@unique([userId, mangaId])
  @@index([userId])
}

model Rating {
  id        String   @id @default(nanoid())
  userId    String
  mangaId   String
  score     Int
  review    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  manga Manga @relation(fields: [mangaId], references: [id], onDelete: Cascade)

  @@unique([userId, mangaId])
  @@index([mangaId])
}

// ─── Billing & subscriptions ────────────────────────────────────────────────

// One row per purchase attempt (audit trail for QPay invoices).
model Payment {
  id            String           @id @default(nanoid())
  userId        String
  plan          SubscriptionPlan
  amount        Int              // MNT (₮), integer
  status        PaymentStatus    @default(PENDING)
  qpayInvoiceId String?          @unique
  qpayPaymentId String?
  createdAt     DateTime         @default(now())
  paidAt        DateTime?

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  subscription Subscription?

  @@index([userId])
  @@index([status])
}

// A granted subscription period. On payment success we extend from
// max(now, current expiry) so re-purchases stack.
model Subscription {
  id        String           @id @default(nanoid())
  userId    String
  plan      SubscriptionPlan
  startedAt DateTime         @default(now())
  expiresAt DateTime
  paymentId String?          @unique
  createdAt DateTime         @default(now())

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  payment Payment? @relation(fields: [paymentId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([expiresAt])
}

// ─── Free-read metering ─────────────────────────────────────────────────────
// Ephemeral rows (pruned by dayKey). userId/chapterId kept as plain strings so
// this stays decoupled from content and cheap to prune. dayKey is the
// Asia/Ulaanbaatar calendar day ("YYYY-MM-DD").

// One row per free (userId, day, chapter) unlock — gives distinct counting and
// idempotency for the per-user 3/day cap.
model FreeReadUsage {
  id        String   @id @default(nanoid())
  userId    String
  ipHash    String
  dayKey    String
  chapterId String
  createdAt DateTime @default(now())

  @@unique([userId, dayKey, chapterId])
  @@index([userId, dayKey])
  @@index([dayKey])
}

// The single account that claimed an IP's free tier for a given day. Any other
// account on the same IP that day gets 0 free reads.
model IpDailyClaim {
  id        String   @id @default(nanoid())
  ipHash    String
  dayKey    String
  userId    String
  createdAt DateTime @default(now())

  @@unique([ipHash, dayKey])
  @@index([dayKey])
}
