generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum MangaStatus {
  ONGOING
  COMPLETED
  HIATUS
}

enum UserRole {
  READER
  ADMIN
}

// ─── Core content ─────────────────────────────────────────────────────────────

model Manga {
  id          String      @id @default(nanoid())
  mangaName   String
  description String?
  coverImage  String?
  author      String?
  artist      String?
  status      MangaStatus @default(ONGOING)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  chapters        Chapter[]
  genres          MangaGenre[]
  ratings         Rating[]
  bookmarks       Bookmark[]
  readingProgress ReadingProgress[]
}

model Genre {
  id   String @id @default(nanoid())
  name String @unique

  mangas MangaGenre[]
}

// Many-to-many join table
model MangaGenre {
  mangaId String
  genreId String

  manga Manga @relation(fields: [mangaId], references: [id], onDelete: Cascade)
  genre Genre @relation(fields: [genreId], references: [id], onDelete: Cascade)

  @@id([mangaId, genreId])
}

model Chapter {
  id            String   @id @default(nanoid())
  mangaId       String
  chapterNumber Float
  title         String?
  publishedAt   DateTime @default(now())
  createdAt     DateTime @default(now())

  manga           Manga             @relation(fields: [mangaId], references: [id], onDelete: Cascade)
  pages           Page[]
  readingProgress ReadingProgress[]

  @@unique([mangaId, chapterNumber])
  @@index([mangaId])
}

model Page {
  id         String @id @default(nanoid())
  chapterId  String
  pageNumber Int
  imageUrl   String
  width      Int?
  height     Int?

  chapter Chapter @relation(fields: [chapterId], references: [id], onDelete: Cascade)

  @@unique([chapterId, pageNumber])
  @@index([chapterId])
}

// ─── Users ────────────────────────────────────────────────────────────────────

model User {
  id           String   @id @default(nanoid())
  email        String   @unique
  clerkId      String   @unique
  username     String?  @unique
  avatarUrl    String?
  role         UserRole @default(READER)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  ratings         Rating[]
  bookmarks       Bookmark[]
  readingProgress ReadingProgress[]
}

// ─── User activity ────────────────────────────────────────────────────────────

model ReadingProgress {
  id         String   @id @default(nanoid())
  userId     String
  mangaId    String
  chapterId  String
  pageNumber Int      @default(1)
  updatedAt  DateTime @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  manga   Manga   @relation(fields: [mangaId], references: [id], onDelete: Cascade)
  chapter Chapter @relation(fields: [chapterId], references: [id], onDelete: Cascade)

  // One progress record per user per manga
  @@unique([userId, mangaId])
  @@index([userId])
}

model Bookmark {
  id        String   @id @default(nanoid())
  userId    String
  mangaId   String
  createdAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  manga Manga @relation(fields: [mangaId], references: [id], onDelete: Cascade)

  @@unique([userId, mangaId])
  @@index([userId])
}

model Rating {
  id        String   @id @default(nanoid())
  userId    String
  mangaId   String
  score     Int
  review    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  manga Manga @relation(fields: [mangaId], references: [id], onDelete: Cascade)

  @@unique([userId, mangaId])
  @@index([mangaId])
}
